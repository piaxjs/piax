{
  "name": "piaxjs",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "pnpm --parallel -F piax -F basic-app dev",
    "dev:piax": "pnpm -F piax dev",
    "dev:basic-app": "pnpm -F basic-app dev",
    "bench": "pnpm -F benchmarks bench",
    "bench:core": "pnpm -F benchmarks bench --apps piax",
    "test": "pnpm -r test",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
